<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchAgent for the native tbled Touch Bar app.

  Install:
    1. Build the app:   cd app && swift build -c release
    2. Copy this file, replacing __TBLED_BIN__ with the built binary path
       (e.g. /Users/you/Projects/.../app/.build/release/tbled-touchbar):
         sed "s#__TBLED_BIN__#$PWD/app/.build/release/tbled-touchbar#" \
           packaging/com.tbled.app.plist > ~/Library/LaunchAgents/com.tbled.app.plist
    3. launchctl load ~/Library/LaunchAgents/com.tbled.app.plist

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.tbled.app.plist
    rm ~/Library/LaunchAgents/com.tbled.app.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tbled.app</string>
    <key>ProgramArguments</key>
    <array>
        <string>__TBLED_BIN__</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>StandardErrorPath</key>
    <string>/tmp/tbled.err.log</string>
    <key>StandardOutPath</key>
    <string>/tmp/tbled.out.log</string>
</dict>
</plist>
